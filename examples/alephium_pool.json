{
  "logging": {
    "level": "info",
    "enableConsoleLog": true,
    "enableConsoleColors": true,
    "logFile": "core.log",
    "apiLogFile": "api.log",
    "logBaseDirectory": "/home/kriptokyng/logs",
    "perPoolLogFile": true
  },
  "notifications": {
    "enabled": true,
    "email": {
      "host": "mail.privateemail.com",
      "port": 465,
      "user": "support@kriptokyng.com",
      "password": "Private",
      "fromAddress": "support@kriptokyng.com",
      "fromName": "Pool Support"
    },
    "admin": {
      "enabled": true,
      "emailAddress": "kriptokyng@gmail.com",
